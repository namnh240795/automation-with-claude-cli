# Multi-Client Keycloak Configuration
# This file contains environment variables for all three components
# Copy the relevant section to each component's .env file

# ============================================================================
# Common Keycloak Configuration (Shared by all clients)
# ============================================================================
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm

# Keycloak Admin Credentials (for management operations)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_this

# ============================================================================
# Frontend Client Configuration
# Client Type: public (browser-based SPA)
# Purpose: User-facing application
# ============================================================================
# For Frontend .env
KEYCLOAK_CLIENT_ID=frontend-client
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URL=https://app.yourdomain.com/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://app.yourdomain.com

# Frontend-specific scopes
KEYCLOAK_SCOPES=openid profile email

# ============================================================================
# CMS Client Configuration
# Client Type: confidential (server-side)
# Purpose: Content Management System
# ============================================================================
# For CMS .env
KEYCLOAK_CLIENT_ID=cms-client
KEYCLOAK_CLIENT_SECRET=<cms-client-secret-from-keycloak>
KEYCLOAK_CALLBACK_URL=https://cms.yourdomain.com/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://cms.yourdomain.com

# CMS-specific scopes
KEYCLOAK_SCOPES=openid profile email cms:read cms:write

# ============================================================================
# Admin Client Configuration
# Client Type: confidential (server-side)
# Purpose: Administrator Panel
# ============================================================================
# For Admin .env
KEYCLOAK_CLIENT_ID=admin-client
KEYCLOAK_CLIENT_SECRET=<admin-client-secret-from-keycloak>
KEYCLOAK_CALLBACK_URL=https://admin.yourdomain.com/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://admin.yourdomain.com

# Admin-specific scopes
KEYCLOAK_SCOPES=openid profile email admin:users admin:system

# ============================================================================
# JWT Configuration (for token validation)
# ============================================================================
KEYCLOAK_ISSUER=http://localhost:8080/realms/app-realm
KEYCLOAK_PUBLIC_KEY=

# ============================================================================
# Development Environment (Local)
# ============================================================================
# For local development, use these URLs instead:
# KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_CALLBACK_URL=http://localhost:3000/auth/callback
# KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# ============================================================================
# Production Environment
# ============================================================================
# For production, use these URLs:
# KEYCLOAK_SERVER_URL=https://auth.yourdomain.com
# KEYCLOAK_CALLBACK_URL=https://app.yourdomain.com/auth/callback
# KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://app.yourdomain.com
