{
  "name": "nestjs-fastify-monorepo",
  "version": "0.0.1",
  "description": "NestJS Fastify Monorepo",
  "author": "",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*",
    "tools"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build:rspack": "BUILD=1 node node_modules/.pnpm/@rspack+cli@*/node_modules/@rspack/cli/bin/rspack.js build",
    "build:auth": "BUILD=1 pnpm --filter auth exec rspack build -c rspack.config.js",
    "dev": "pnpm rspack:auth",
    "dev:auth": "pnpm --filter auth exec rspack serve -c rspack.config.js",
    "rspack:auth": "pnpm --filter auth exec rspack serve -c rspack.config.js",
    "start:auth": "cd apps/auth && node dist/main.js",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@rspack/cli": "^1.7.6",
    "@rspack/core": "^1.7.6",
    "@rspack/dev-server": "^1.2.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "pg": "^8.18.0",
    "prettier": "^3.0.0",
    "prisma": "^7.4.1",
    "rimraf": "^6.0.0",
    "run-script-webpack-plugin": "^0.2.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "zhipuai": "^2.0.0"
  }
}
