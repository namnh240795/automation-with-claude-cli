# Admin Client Environment Configuration
# This file is for the Administrator Panel
# Client ID: admin-client
# Access Type: confidential (server-side)

# Service Configuration
SERVICE_PREFIX=admin
PORT=3002
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3002,http://localhost:4200
CORS_ORIGIN_REGEX=^https://admin\..*\.yourdomain\.com$

# Database - Admin Service (admin_db)
DATABASE_URL="postgresql://admin_admin:admin_admin_password_change_this@localhost:5432/admin_db?schema=public"

# Keycloak Configuration
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm
KEYCLOAK_CLIENT_ID=admin-client
KEYCLOAK_CLIENT_SECRET=<get-from-keycloak-admin-console>

# OAuth/OIDC Configuration
KEYCLOAK_CALLBACK_URL=http://localhost:3002/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3002

# Admin-specific scopes
KEYCLOAK_SCOPES=openid profile email admin:users admin:system

# JWT Configuration
KEYCLOAK_ISSUER=http://localhost:8080/realms/app-realm
KEYCLOAK_PUBLIC_KEY=

# Keycloak Admin Credentials (required for admin operations)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_this

# User Management Configuration
USER_MANAGEMENT_ENABLED=true
ROLE_ASSIGNMENT_ENABLED=true
SYSTEM_CONFIG_ACCESS=true
