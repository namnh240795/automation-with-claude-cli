# CMS Client Environment Configuration
# This file is for the Content Management System
# Client ID: cms-client
# Access Type: confidential (server-side)

# Service Configuration
SERVICE_PREFIX=cms
PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:4200
CORS_ORIGIN_REGEX=^https://cms\..*\.yourdomain\.com$

# Database - CMS Service (cms_db)
DATABASE_URL="postgresql://cms_admin:cms_admin_password_change_this@localhost:5432/cms_db?schema=public"

# Keycloak Configuration
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm
KEYCLOAK_CLIENT_ID=cms-client
KEYCLOAK_CLIENT_SECRET=<get-from-keycloak-admin-console>

# OAuth/OIDC Configuration
KEYCLOAK_CALLBACK_URL=http://localhost:3001/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3001

# CMS-specific scopes
KEYCLOAK_SCOPES=openid profile email cms:read cms:write

# JWT Configuration
KEYCLOAK_ISSUER=http://localhost:8080/realms/app-realm
KEYCLOAK_PUBLIC_KEY=

# Keycloak Admin Credentials (for CMS user management)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_this
