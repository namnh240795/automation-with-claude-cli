// RAG Database Schema
// Uses Prisma 7 with driver adapters

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Document source types (matches database enum)
enum source_type {
  DATABASE_POST
  DATABASE_COMMENT
  DATABASE_USER
  CODEBASE_SOURCE
  CODEBASE_MARKDOWN
  CODEBASE_TYPESCRIPT
  CODEBASE_JAVASCRIPT
  CODEBASE_PRISMA
  CODEBASE_JSON
}

// Document types (matches database enum)
enum doc_type {
  MARKDOWN
  TYPESCRIPT
  JAVASCRIPT
  PRISMA_SCHEMA
  JSON
  YAML
  TEXT
}

// Job status (matches database enum)
enum job_status {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// Document - stores source content
model document {
  id               String      @id
  source_type      source_type
  doc_type         doc_type
  title            String
  file_path        String      @unique
  file_path_hash   String      @unique
  content          String      @db.Text
  metadata         Json?
  indexed_at       DateTime    @default(now()) @db.Timestamp(3)
  updated_at       DateTime    @db.Timestamp(3)

  // Relations
  chunks           document_chunk[]
  indexing_jobs    indexing_job[]

  @@index([source_type])
  @@index([file_path_hash])
  @@map("document")
}

// Document Chunk - split documents with embeddings
model document_chunk {
  id              String      @id
  document_id     String
  chunk_index     Int
  content         String      @db.Text
  embedding       Unsupported("vector(1024)")?
  metadata        Json?
  created_at      DateTime    @default(now()) @db.Timestamp(3)

  // Relations
  document        document    @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([chunk_index])
  @@map("document_chunk")
}

// Embedding Provider Configuration
model embedding_provider {
  id              String      @id
  name            String      @unique
  provider_type   String
  api_key         String?
  api_endpoint    String?
  model_name      String
  dimensions      Int
  is_active       Boolean     @default(true)
  created_at      DateTime    @default(now()) @db.Timestamp(3)
  updated_at      DateTime    @db.Timestamp(3)

  @@index([is_active])
  @@index([provider_type])
  @@map("embedding_provider")
}

// Indexing Job Tracking
model indexing_job {
  id                    String      @id
  status                job_status  @default(PENDING)
  source                String
  documents_indexed     Int         @default(0)
  chunks_created        Int         @default(0)
  error_message         String?     @db.Text
  started_at            DateTime    @default(now()) @db.Timestamp(3)
  completed_at          DateTime?   @db.Timestamp(3)

  // Relations
  documents             document[]

  @@index([source])
  @@index([status])
  @@map("indexing_job")
}
