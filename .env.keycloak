# Keycloak Configuration
# Copy this file to .env.local or add to your service's .env file

# Keycloak Server Configuration
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm
KEYCLOAK_CLIENT_ID=app-client
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Keycloak Admin Credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_this

# OAuth/OIDC Configuration
KEYCLOAK_CALLBACK_URL=http://localhost:3000/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# JWT Configuration (for token validation)
KEYCLOAK_PUBLIC_KEY=
KEYCLOAK_ISSUER=http://localhost:8080/realms/app-realm

# Social Login Providers
# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Facebook OAuth2
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
