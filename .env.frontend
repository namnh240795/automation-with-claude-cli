# Frontend Client Environment Configuration
# This file is for the user-facing frontend application
# Client ID: frontend-client
# Access Type: public (browser-based SPA)

# Service Configuration
SERVICE_PREFIX=frontend
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:4200
CORS_ORIGIN_REGEX=^https://.*\.yourdomain\.com$

# Keycloak Configuration
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=app-realm
KEYCLOAK_CLIENT_ID=frontend-client
# Frontend client is public, no secret needed
KEYCLOAK_CLIENT_SECRET=

# OAuth/OIDC Configuration
KEYCLOAK_CALLBACK_URL=http://localhost:3000/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Frontend-specific scopes
KEYCLOAK_SCOPES=openid profile email

# JWT Configuration
KEYCLOAK_ISSUER=http://localhost:8080/realms/app-realm
KEYCLOAK_PUBLIC_KEY=

# Social Login Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
